---
import Layout from '../layouts/Layout.astro';

const title = "Product | Zero Method - AI Prompts Starter Pack";
const description = "25 battle-tested AI prompts + 10 email templates for $19. Save 5 hours every week.";
---

<Layout title={title} description={description}>
    <!-- Header -->
    <header class="bg-slate-900 border-b border-slate-800">
        <div class="max-w-6xl mx-auto px-6 py-4">
            <a href="/" class="text-xl font-bold bg-gradient-to-r from-cyan-400 to-purple-500 bg-clip-text text-transparent">
                ◈ Zero Method
            </a>
        </div>
    </header>

    <!-- Product Hero -->
    <section class="py-20 px-6">
        <div class="max-w-4xl mx-auto">
            <div class="text-center mb-12">
                <h1 class="text-4xl md:text-5xl font-bold mb-4">25 AI Prompts + 10 Email Templates</h1>
                <p class="text-xl text-slate-400">Save 5 hours every week with copy-paste ready prompts for ChatGPT and Claude.</p>
            </div>

            <!-- Pricing Card -->
            <div class="max-w-md mx-auto bg-slate-800 rounded-2xl p-8 border border-slate-700">
                <div class="text-center mb-6">
                    <div class="text-sm text-slate-400 mb-2">One-time payment</div>
                    <div class="text-5xl font-bold text-white">$19</div>
                    <div class="text-slate-400 mt-2">No subscription. No upsells.</div>
                </div>

                <ul class="space-y-3 mb-8">
                    <li class="flex items-center gap-3">
                        <span class="text-cyan-400">✓</span>
                        <span>25 AI Prompts (5 categories)</span>
                    </li>
                    <li class="flex items-center gap-3">
                        <span class="text-cyan-400">✓</span>
                        <span>10 Email Templates</span>
                    </li>
                    <li class="flex items-center gap-3">
                        <span class="text-cyan-400">✓</span>
                        <span>PDF + Markdown formats</span>
                    </li>
                    <li class="flex items-center gap-3">
                        <span class="text-cyan-400">✓</span>
                        <span>Usage instructions</span>
                    </li>
                    <li class="flex items-center gap-3">
                        <span class="text-cyan-400">✓</span>
                        <span>Free updates (1 year)</span>
                    </li>
                </ul>

                <!-- Email Input Form -->
                <form id="checkout-form" class="space-y-4">
                    <div>
                        <input 
                            type="email" 
                            id="email" 
                            name="email"
                            placeholder="Enter your email" 
                            required
                            class="w-full px-4 py-3 bg-slate-900 border border-slate-600 rounded-lg text-white placeholder-slate-500 focus:outline-none focus:border-cyan-400 transition"
                        />
                        <p id="email-error" class="text-red-400 text-sm mt-2 hidden">Please enter a valid email address</p>
                    </div>

                    <div class="space-y-3">
                        <button 
                            type="submit" 
                            id="stripe-btn"
                            class="w-full py-4 bg-gradient-to-r from-cyan-400 to-purple-500 rounded-lg font-semibold text-slate-900 hover:opacity-90 transition flex items-center justify-center gap-2"
                        >
                            <span>Pay with Card (Stripe) — $19</span>
                        </button>

                        <button 
                            type="button" 
                            id="paypal-btn"
                            class="w-full py-4 bg-[#0070ba] rounded-lg font-semibold text-white hover:bg-[#005ea6] transition flex items-center justify-center gap-2"
                        >
                            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M7.076 21.337H2.47a.641.641 0 0 1-.633-.74L4.944.901C5.026.382 5.474 0 5.998 0h7.46c2.57 0 4.578.543 5.69 1.81 1.01 1.15 1.304 2.42 1.012 4.287-.023.143-.047.288-.077.437-.983 5.05-4.349 6.797-8.647 6.797h-2.19c-.524 0-.968.382-1.05.9l-.8 5.115-.252 1.602a.64.64 0 0 1-.631.74H7.076zm12.386-13.11c.024-.143.047-.288.077-.437.456-2.35-.083-3.965-1.217-5.224-1.14-1.264-3.141-1.935-5.695-1.935H7.028c-.524 0-.968.382-1.05.9L4.69 9.255h2.19c2.57 0 4.578-.543 5.69-1.81 1.01-1.15 1.304-2.42 1.012-4.287l-1.55 9.87h2.19c2.57 0 4.578-.543 5.69-1.81.005-.006.01-.012.015-.017z"/>
                            </svg>
                            <span>Pay with PayPal — $19</span>
                        </button>
                    </div>

                    <div id="loading" class="hidden text-center py-4">
                        <div class="inline-flex items-center gap-2">
                            <div class="w-5 h-5 border-2 border-slate-600 border-t-cyan-400 rounded-full animate-spin"></div>
                            <span class="text-slate-400">Processing...</span>
                        </div>
                    </div>

                    <div id="error-message" class="hidden p-4 bg-red-900/50 border border-red-500 rounded-lg text-red-200 text-sm">
                    </div>
                </form>

                <p class="text-center text-sm text-slate-500 mt-4">
                    30-day money-back guarantee
                </p>
            </div>
        </div>
    </section>

    <!-- FAQ -->
    <section class="py-20 px-6 bg-slate-900/50">
        <div class="max-w-3xl mx-auto">
            <h2 class="text-3xl font-bold text-center mb-12">Frequently Asked Questions</h2>

            <div class="space-y-6">
                <div class="p-6 bg-slate-800 rounded-xl border border-slate-700">
                    <h3 class="font-semibold mb-2">What's actually included?</h3>
                    <p class="text-slate-400">You get 25 AI prompts across 5 categories (Email, Reports, Content, Productivity, Research) plus 10 professional email templates. Everything is delivered as PDF and Markdown files.</p>
                </div>

                <div class="p-6 bg-slate-800 rounded-xl border border-slate-700">
                    <h3 class="font-semibold mb-2">Do I need technical skills?</h3>
                    <p class="text-slate-400">Not at all. If you can copy and paste, you can use these prompts. Simply copy the prompt template, fill in your specific details, and paste into ChatGPT or Claude.</p>
                </div>

                <div class="p-6 bg-slate-800 rounded-xl border border-slate-700">
                    <h3 class="font-semibold mb-2">What if I'm not satisfied?</h3>
                    <p class="text-slate-400">30-day money-back guarantee. If these prompts don't save you time, email us within 30 days for a full refund. No questions asked.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="py-8 px-6 border-t border-slate-800">
        <div class="max-w-6xl mx-auto text-center text-slate-500">
            <p>© 2026 Zero Method. Built with ◈.</p>
        </div>
    </footer>

    <script>
        const form = document.getElementById('checkout-form');
        const emailInput = document.getElementById('email');
        const emailError = document.getElementById('email-error');
        const stripeBtn = document.getElementById('stripe-btn');
        const paypalBtn = document.getElementById('paypal-btn');
        const loading = document.getElementById('loading');
        const errorMessage = document.getElementById('error-message');

        function showError(msg) {
            errorMessage.textContent = msg;
            errorMessage.classList.remove('hidden');
        }

        function hideError() {
            errorMessage.classList.add('hidden');
        }

        function setLoading(isLoading) {
            if (isLoading) {
                loading.classList.remove('hidden');
                stripeBtn.disabled = true;
                paypalBtn.disabled = true;
                stripeBtn.classList.add('opacity-50');
                paypalBtn.classList.add('opacity-50');
            } else {
                loading.classList.add('hidden');
                stripeBtn.disabled = false;
                paypalBtn.disabled = false;
                stripeBtn.classList.remove('opacity-50');
                paypalBtn.classList.remove('opacity-50');
            }
        }

        function validateEmail(email) {
            return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
        }

        // Stripe Checkout
        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            hideError();

            const email = emailInput.value.trim();
            
            if (!validateEmail(email)) {
                emailError.classList.remove('hidden');
                return;
            }
            emailError.classList.add('hidden');

            setLoading(true);

            try {
                const response = await fetch('/api/create-checkout-session', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email }),
                });

                const data = await response.json();

                if (data.url) {
                    window.location.href = data.url;
                } else {
                    throw new Error(data.error || 'Failed to create checkout session');
                }
            } catch (err) {
                setLoading(false);
                showError(err.message || 'Something went wrong. Please try again.');
            }
        });

        // PayPal Checkout
        paypalBtn.addEventListener('click', async () => {
            hideError();

            const email = emailInput.value.trim();
            
            if (!validateEmail(email)) {
                emailError.classList.remove('hidden');
                return;
            }
            emailError.classList.add('hidden');

            setLoading(true);

            try {
                const response = await fetch('/api/create-paypal-order', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email }),
                });

                const data = await response.json();

                if (data.url) {
                    // Store email in session for PayPal return
                    sessionStorage.setItem('customerEmail', email);
                    window.location.href = data.url;
                } else {
                    throw new Error(data.error || 'Failed to create PayPal order');
                }
            } catch (err) {
                setLoading(false);
                showError(err.message || 'Something went wrong. Please try again.');
            }
        });
    </script>
</Layout>