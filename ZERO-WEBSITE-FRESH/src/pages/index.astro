---
import Layout from '../layouts/Layout.astro';

const title = "Zero Method | 25 AI Prompts That Save 5 Hours a Week";
const description = "25 battle-tested AI prompts + 10 email templates. $19 one-time. Copy-paste ready.";
---

<Layout title={title} description={description}>
    <!-- Header -->
    <header class="bg-slate-900 border-b border-slate-800">
        <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
            <a href="/" class="text-xl font-bold bg-gradient-to-r from-cyan-400 to-purple-500 bg-clip-text text-transparent">
                ◈ Zero Method
            </a>
            <nav class="flex gap-6">
                <a href="/" class="text-slate-300 hover:text-white transition">Home</a>
                <a href="/product" class="text-slate-300 hover:text-white transition">Product</a>
            </nav>
        </div>
    </header>

    <!-- Hero -->
    <section class="py-20 px-6">
        <div class="max-w-4xl mx-auto text-center">
            <div class="inline-flex items-center gap-2 px-4 py-2 bg-slate-800 rounded-full text-sm text-cyan-400 mb-8">
                <span class="w-2 h-2 bg-cyan-400 rounded-full animate-pulse"></span>
                25 AI Prompts + 10 Email Templates
            </div>

            <h1 class="text-5xl md:text-6xl font-bold mb-6 leading-tight">
                The AI Prompts That Save <span class="bg-gradient-to-r from-cyan-400 to-purple-500 bg-clip-text text-transparent">5 Hours Every Week</span>
            </h1>

            <p class="text-xl text-slate-400 mb-10 max-w-2xl mx-auto">
                25 battle-tested prompts and 10 email templates. 
                Copy-paste ready for ChatGPT and Claude.
            </p>

            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a href="/product" class="px-8 py-4 bg-gradient-to-r from-cyan-400 to-purple-500 rounded-lg font-semibold text-slate-900 hover:opacity-90 transition">
                    Get the Pack — $19
                </a>
            </div>

            <p class="text-slate-500 text-sm mt-6">
                30-day money-back guarantee • One-time payment • Instant download
            </p>
        </div>
    </section>

    <!-- What's Included -->
    <section class="py-20 px-6 bg-slate-900/50">
        <div class="max-w-6xl mx-auto">
            <h2 class="text-3xl font-bold text-center mb-12">What's Included</h2>

            <div class="grid md:grid-cols-3 gap-8">
                <div class="p-6 bg-slate-800 rounded-xl border border-slate-700">
                    <div class="text-4xl mb-4">🚀</div>
                    <h3 class="text-xl font-semibold mb-2">25 AI Prompts</h3>
                    <p class="text-slate-400">Battle-tested across ChatGPT, Claude, and Gemini. Each prompt includes clear instructions.</p>
                </div>

                <div class="p-6 bg-slate-800 rounded-xl border border-slate-700">
                    <div class="text-4xl mb-4">📄</div>
                    <h3 class="text-xl font-semibold mb-2">10 Email Templates</h3>
                    <p class="text-slate-400">Professional email templates for cold outreach, follow-ups, and difficult conversations.</p>
                </div>

                <div class="p-6 bg-slate-800 rounded-xl border border-slate-700">
                    <div class="text-4xl mb-4">🔄</div>
                    <h3 class="text-xl font-semibold mb-2">Free Updates</h3>
                    <p class="text-slate-400">Get updates for 1 year after purchase. As we improve the prompts, you get the improvements.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-20 px-6">
        <div class="max-w-3xl mx-auto text-center">
            <h2 class="text-3xl font-bold mb-4">Ready to Save 5 Hours Every Week?</h2>
            
            <p class="text-slate-400 mb-8">
                Get instant access to 25 proven AI prompts and 10 email templates.
            </p>

            <a href="/product" class="inline-block px-8 py-4 bg-gradient-to-r from-cyan-400 to-purple-500 rounded-lg font-semibold text-slate-900 hover:opacity-90 transition">
                Get Started — $19
            </a>
        </div>
    </section>

    <!-- Footer -->
    <footer class="py-8 px-6 border-t border-slate-800">
        <div class="max-w-6xl mx-auto text-center text-slate-500">
            <p>© 2026 Zero Method. Built with ◈.</p>
            <div class="flex justify-center gap-4 mt-4">
                <a href="/privacy" class="hover:text-white transition">Privacy</a>
                <a href="/terms" class="hover:text-white transition">Terms</a>
            </div>
        </div>
    </footer>
</Layout>