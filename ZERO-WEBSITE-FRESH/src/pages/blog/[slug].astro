---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

// Get related posts (same tags, excluding current)
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter(p => 
    p.slug !== post.slug && 
    p.data.tags?.some(tag => post.data.tags?.includes(tag))
  )
  .slice(0, 3);

const formattedDate = new Date(post.data.pubDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<Layout title={`${post.data.title} | Zero Method`} description={post.data.description}>
  <div class="min-h-screen bg-slate-950">
    {/* Navigation */}
    <nav class="border-b border-slate-800/50 bg-slate-950/80 backdrop-blur-md sticky top-0 z-50">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
        <div class="flex items-center justify-between">
          <a href="/" class="text-lg font-bold text-white hover:text-emerald-400 transition-colors">
            Zero Method
          </a>
          <div class="flex items-center gap-6">
            <a href="/blog" class="text-sm font-medium text-emerald-400">Blog</a>
            <a href="/product" class="text-sm font-medium text-slate-400 hover:text-white transition-colors">Product</a>
          </div>
        </div>
      </div>
    </nav>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      {/* Back Link */}
      <div class="py-6">
        <a 
          href="/blog" 
          class="inline-flex items-center text-sm font-medium text-slate-500 hover:text-emerald-400 transition-colors"
        >
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to all posts
        </a>
      </div>

      {/* Article */}
      <article class="py-8 sm:py-12">
        {/* Header */}
        <header class="mb-10 sm:mb-12">
          {/* Tags */}
          {post.data.tags && post.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-4">
              {post.data.tags.map((tag) => (
                <a 
                  href={`/blog?tag=${tag}`}
                  class="px-3 py-1 text-xs font-medium bg-emerald-500/10 text-emerald-400 rounded-full hover:bg-emerald-500/20 transition-colors"
                >
                  #{tag}
                </a>
              ))}
            </div>
          )}
          
          <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white mb-4 leading-tight">
            {post.data.title}
          </h1>
          
          <p class="text-lg sm:text-xl text-slate-400 leading-relaxed mb-6">
            {post.data.description}
          </p>
          
          <div class="flex flex-wrap items-center gap-4 text-sm text-slate-500">
            <div class="flex items-center gap-2">
              <div class="w-8 h-8 rounded-full bg-gradient-to-br from-emerald-500 to-emerald-700 flex items-center justify-center text-white font-bold text-xs">
                {post.data.author.charAt(0)}
              </div>
              <span class="font-medium text-slate-300">{post.data.author}</span>
            </div>
            <span class="text-slate-600">•</span>
            <time datetime={post.data.pubDate.toISOString()} class="text-slate-400">
              {formattedDate}
            </time>
          </div>
        </header>

        {/* Content */}
        <div class="prose prose-lg prose-invert max-w-none">
          <Content />
        </div>
      </article>

      {/* CTA */}
      <section class="py-12 border-t border-slate-800/50">
        <div class="bg-slate-900/50 border border-slate-800 rounded-2xl p-6 sm:p-8">
          <h3 class="text-xl sm:text-2xl font-bold text-white mb-3">
            Want More Zero Method?
          </h3>
          <p class="text-slate-400 mb-6 leading-relaxed">
            Get the complete starter pack with 25 proven AI prompts and 10 battle-tested email templates. Start saving hours every week.
          </p>
          <a 
            href="/product" 
            class="inline-flex items-center justify-center px-6 py-3 bg-emerald-500 hover:bg-emerald-600 text-slate-950 font-semibold rounded-lg transition-colors"
          >
            Get the Starter Pack →
          </a>
        </div>
      </section>

      {/* Related Posts */}
      {relatedPosts.length > 0 && (
        <section class="py-12 border-t border-slate-800/50">
          <h3 class="text-lg font-semibold text-white mb-6 flex items-center gap-2">
            <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
            </svg>
            Related Reading
          </h3>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {relatedPosts.map((relatedPost) => (
              <a 
                href={`/blog/${relatedPost.slug}`}
                class="group block bg-slate-900/50 border border-slate-800 rounded-xl p-5 hover:border-emerald-500/50 hover:bg-slate-800/50 transition-all"
              >
                <div class="flex flex-wrap gap-2 mb-3">
                  {relatedPost.data.tags?.slice(0, 2).map((tag) => (
                    <span class="px-2 py-0.5 text-xs font-medium bg-emerald-500/10 text-emerald-400 rounded-full">
                      {tag}
                    </span>
                  ))}
                </div>
                <h4 class="font-semibold text-white mb-2 group-hover:text-emerald-400 transition-colors">
                  {relatedPost.data.title}
                </h4>
                <p class="text-sm text-slate-400 line-clamp-2">
                  {relatedPost.data.description}
                </p>
              </a>
            ))}
          </div>
        </section>
      )}
    </div>

    {/* Footer */}
    <footer class="border-t border-slate-800/50 py-8 mt-8">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <p class="text-slate-500 text-sm">© 2026 Zero Method. All rights reserved.</p>
          <a 
            href="/rss.xml" 
            class="text-sm text-slate-500 hover:text-emerald-400 transition-colors flex items-center gap-2"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
              <path d="M3.75 3a.75.75 0 00-.75.75v.5c0 .414.336.75.75.75h.5a.75.75 0 00.75-.75v-.5A.75.75 0 004.25 3h-.5zM3.75 8a.75.75 0 00-.75.75v.5c0 .414.336.75.75.75h.5a.75.75 0 00.75-.75v-.5A.75.75 0 004.25 8h-.5zM3.75 13a.75.75 0 00-.75.75v.5c0 .414.336.75.75.75h.5a.75.75 0 00.75-.75v-.5a.75.75 0 00-.75-.75h-.5zM8 5.25a.75.75 0 01.75-.75h.5a.75.75 0 01.75.75v.5a.75.75 0 01-.75.75h-.5a.75.75 0 01-.75-.75v-.5zM8 10.25a.75.75 0 01.75-.75h.5a.75.75 0 01.75.75v.5a.75.75 0 01-.75.75h-.5a.75.75 0 01-.75-.75v-.5zM8 15.25a.75.75 0 01.75-.75h.5a.75.75 0 01.75.75v.5a.75.75 0 01-.75.75h-.5a.75.75 0 01-.75-.75v-.5z" />
            </svg>
            RSS Feed
          </a>
        </div>
      </div>
    </footer>
  </div>

  <style>
    /* Typography */
    .prose {
      color: var(--tw-prose-body);
    }
    
    .prose :where(h1):not(:where([class~="not-prose"] *)) {
      color: #ffffff;
      font-size: 2.25rem;
      font-weight: 700;
      margin-top: 0;
      margin-bottom: 1rem;
      line-height: 1.2;
    }
    
    .prose :where(h2):not(:where([class~="not-prose"] *)) {
      color: #ffffff;
      font-size: 1.875rem;
      font-weight: 700;
      margin-top: 2.5rem;
      margin-bottom: 1rem;
      line-height: 1.3;
    }
    
    .prose :where(h3):not(:where([class~="not-prose"] *)) {
      color: #ffffff;
      font-size: 1.5rem;
      font-weight: 600;
      margin-top: 2rem;
      margin-bottom: 0.75rem;
      line-height: 1.4;
    }
    
    .prose :where(p):not(:where([class~="not-prose"] *)) {
      color: #94a3b8;
      margin-bottom: 1.25rem;
      line-height: 1.75;
    }
    
    .prose :where(strong):not(:where([class~="not-prose"] *)) {
      color: #ffffff;
      font-weight: 600;
    }
    
    .prose :where(a):not(:where([class~="not-prose"] *)) {
      color: #34d399;
      text-decoration: none;
      transition: color 0.2s;
    }
    
    .prose :where(a):not(:where([class~="not-prose"] *)):hover {
      color: #6ee7b7;
    }
    
    .prose :where(ul):not(:where([class~="not-prose"] *)) {
      list-style-type: disc;
      padding-left: 1.5rem;
      margin-bottom: 1.25rem;
    }
    
    .prose :where(ol):not(:where([class~="not-prose"] *)) {
      list-style-type: decimal;
      padding-left: 1.5rem;
      margin-bottom: 1.25rem;
    }
    
    .prose :where(li):not(:where([class~="not-prose"] *)) {
      color: #94a3b8;
      margin-bottom: 0.5rem;
    }
    
    .prose :where(blockquote):not(:where([class~="not-prose"] *)) {
      border-left: 4px solid #10b981;
      padding-left: 1rem;
      font-style: italic;
      color: #94a3b8;
      margin: 1.5rem 0;
    }
    
    .prose :where(code):not(:where([class~="not-prose"] *)) {
      background-color: rgba(30, 41, 59, 0.8);
      color: #e2e8f0;
      padding: 0.25rem 0.5rem;
      border-radius: 0.375rem;
      font-family: ui-monospace, monospace;
      font-size: 0.875em;
    }
    
    .prose :where(pre):not(:where([class~="not-prose"] *)) {
      background-color: rgba(15, 23, 42, 0.8);
      padding: 1rem;
      border-radius: 0.5rem;
      overflow-x: auto;
      margin-bottom: 1.25rem;
    }
    
    .prose :where(pre code):not(:where([class~="not-prose"] *)) {
      background-color: transparent;
      padding: 0;
      color: inherit;
    }
    
    .prose :where(hr):not(:where([class~="not-prose"] *)) {
      border-color: rgba(51, 65, 85, 0.5);
      margin: 2rem 0;
    }
  </style>
</Layout>