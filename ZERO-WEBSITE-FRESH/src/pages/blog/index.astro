---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/blog/PostCard.astro';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featuredPosts = sortedPosts.filter(post => post.data.featured);
const regularPosts = sortedPosts.filter(post => !post.data.featured);

const allTags = [...new Set(posts.flatMap(post => post.data.tags || []))];
---

<Layout title="Blog | Zero Method" description="Practical productivity insights without the noise.">
  <div class="min-h-screen bg-slate-950">
    {/* Navigation */}
    <nav class="border-b border-slate-800/50 bg-slate-950/80 backdrop-blur-md sticky top-0 z-50">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
        <div class="flex items-center justify-between">
          <a href="/" class="text-lg font-bold text-white hover:text-emerald-400 transition-colors">
            Zero Method
          </a>
          <div class="flex items-center gap-6">
            <a href="/blog" class="text-sm font-medium text-emerald-400">Blog</a>
            <a href="/product" class="text-sm font-medium text-slate-400 hover:text-white transition-colors">Product</a>
          </div>
        </div>
      </div>
    </nav>

    {/* Header */}
    <header class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-8 sm:pt-16 sm:pb-12">
      <div class="max-w-2xl">
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white mb-4 leading-tight">
          The Signal
        </h1>
        <p class="text-lg sm:text-xl text-slate-400 leading-relaxed">
          Practical productivity insights without the noise. No fluff, just what works.
        </p>
      </div>
    </header>

    {/* Tag Filter - Mobile friendly */}
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-8">
      <div class="flex flex-wrap gap-2">
        <a href="/blog" class="px-3 py-1.5 text-sm font-medium bg-emerald-500/20 text-emerald-400 rounded-full">
          All
        </a>
        {allTags.map((tag) => (
          <span class="px-3 py-1.5 text-sm font-medium bg-slate-800 text-slate-400 rounded-full cursor-pointer hover:bg-slate-700 transition-colors">
            #{tag}
          </span>
        ))}
      </div>
    </div>

    {/* Featured Section */}
    {featuredPosts.length > 0 && (
      <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
        <div class="flex items-center gap-3 mb-6">
          <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
          <h2 class="text-sm font-semibold text-emerald-400 uppercase tracking-wider">Featured</h2>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {featuredPosts.map((post) => (
            <PostCard 
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              author={post.data.author}
              tags={post.data.tags}
              slug={post.slug}
              featured={post.data.featured}
            />
          ))}
        </div>
      </section>
    )}

    {/* All Posts */}
    <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-2 h-2 rounded-full bg-slate-500"></span>
        <h2 class="text-sm font-semibold text-slate-400 uppercase tracking-wider">Latest</h2>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {regularPosts.map((post) => (
          <PostCard 
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            author={post.data.author}
            tags={post.data.tags}
            slug={post.slug}
          />
        ))}
      </div>
    </section>

    {/* CTA Section */}
    <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="bg-gradient-to-br from-emerald-500/10 via-slate-900 to-slate-950 border border-emerald-500/20 rounded-2xl p-6 sm:p-8 md:p-12 text-center">
        <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">
          Ready to Take Control of Your Time?
        </h2>
        <p class="text-slate-400 mb-8 max-w-xl mx-auto">
          Get the complete Zero Method starter pack with 25 proven prompts and 10 battle-tested email templates.
        </p>
        <a 
          href="/product" 
          class="inline-flex items-center justify-center px-6 py-3 bg-emerald-500 hover:bg-emerald-600 text-slate-950 font-semibold rounded-lg transition-colors"
        >
          Get the Starter Pack →
        </a>
      </div>
    </section>

    {/* Footer */}
    <footer class="border-t border-slate-800/50 py-8">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <p class="text-slate-500 text-sm">© 2026 Zero Method. All rights reserved.</p>
          <a 
            href="/rss.xml" 
            class="text-sm text-slate-500 hover:text-emerald-400 transition-colors flex items-center gap-2"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
              <path d="M3.75 3a.75.75 0 00-.75.75v.5c0 .414.336.75.75.75h.5a.75.75 0 00.75-.75v-.5A.75.75 0 004.25 3h-.5zM3.75 8a.75.75 0 00-.75.75v.5c0 .414.336.75.75.75h.5a.75.75 0 00.75-.75v-.5A.75.75 0 004.25 8h-.5zM3.75 13a.75.75 0 00-.75.75v.5c0 .414.336.75.75.75h.5a.75.75 0 00.75-.75v-.5a.75.75 0 00-.75-.75h-.5zM8 5.25a.75.75 0 01.75-.75h.5a.75.75 0 01.75.75v.5a.75.75 0 01-.75.75h-.5a.75.75 0 01-.75-.75v-.5zM8 10.25a.75.75 0 01.75-.75h.5a.75.75 0 01.75.75v.5a.75.75 0 01-.75.75h-.5a.75.75 0 01-.75-.75v-.5zM8 15.25a.75.75 0 01.75-.75h.5a.75.75 0 01.75.75v.5a.75.75 0 01-.75.75h-.5a.75.75 0 01-.75-.75v-.5z" />
            </svg>
            RSS Feed
          </a>
        </div>
      </div>
    </footer>
  </div>
</Layout>