---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';

const { token } = Astro.params;

// Check token validity via API
const response = await fetch(`${Astro.url.origin}/api/validate-token?token=${token}`);
const data = await response.json();
---

<Layout title="Download | Zero Method" description="Download your AI Prompts Starter Pack">
  <header class="bg-slate-900 border-b border-slate-800">
    <div class="max-w-6xl mx-auto px-6 py-4">
      <a href="/" class="text-xl font-bold bg-gradient-to-r from-cyan-400 to-purple-500 bg-clip-text text-transparent">
        ◈ Zero Method
      </a>
    </div>
  </header>

  <main class="py-20 px-6">
    <div class="max-w-xl mx-auto">
      {data.valid ? (
        <div class="bg-slate-800 rounded-2xl p-8 border border-slate-700 text-center">
          <div class="text-6xl mb-6">📦</div>
          <h1 class="text-3xl font-bold mb-4">Your download is ready</h1>
          <p class="text-slate-400 mb-8">
            Click below to download your Zero Method AI Prompts Starter Pack.
            This link is valid for 7 days and can be used multiple times.
          </p>

          <a 
            href={`/api/download/${token}`}
            class="inline-block w-full py-4 bg-gradient-to-r from-cyan-400 to-purple-500 rounded-lg font-semibold text-slate-900 text-center hover:opacity-90 transition"
          >
            Download Starter Pack (ZIP)
          </a>

          <div class="mt-8 text-left p-4 bg-slate-900/50 rounded-lg">
            <h3 class="font-semibold mb-2">What's included:</h3>
            <ul class="text-sm text-slate-400 space-y-1">
              <li>✓ 25 AI Prompts (PDF + Markdown)</li>
              <li>✓ 10 Email Templates</li>
              <li>✓ Usage Instructions</li>
            </ul>
          </div>

          {data.downloaded && (
            <p class="text-sm text-slate-500 mt-6">
              Last downloaded: {new Date(data.downloadedAt).toLocaleString()}
            </p>
          )}
        </div>
      ) : (
        <div class="bg-slate-800 rounded-2xl p-8 border border-slate-700 text-center">
          <div class="text-6xl mb-6">🔒</div>
          <h1 class="text-3xl font-bold mb-4">Download unavailable</h1>
          <p class="text-slate-400 mb-8">
            {data.error === 'Token expired' 
              ? 'This download link has expired. Please contact support for assistance.' 
              : 'Invalid download link. Please check your email for the correct link.'}
          </p>

          <a 
            href="/product"
            class="inline-block px-6 py-3 bg-slate-700 rounded-lg font-semibold text-white hover:bg-slate-600 transition"
          >
            Go to Product Page
          </a>
        </div>
      )}
    </div>
  </main>

  <footer class="py-8 px-6 border-t border-slate-800">
    <div class="max-w-6xl mx-auto text-center text-slate-500">
      <p>© 2026 Zero Method. Built with ◈.</p>
    </div>
  </footer>
</Layout>