---
import Layout from '../layouts/Layout.astro';

const title = "Payment Successful | Zero Method";
const description = "Thank you for your purchase! Check your email for download instructions.";
---

<Layout title={title} description={description}>
  <!-- Header -->
  <header class="bg-slate-900 border-b border-slate-800">
    <div class="max-w-6xl mx-auto px-6 py-4">
      <a href="/" class="text-xl font-bold bg-gradient-to-r from-cyan-400 to-purple-500 bg-clip-text text-transparent">
        ◈ Zero Method
      </a>
    </div>
  </header>

  <!-- Success Content -->
  <section class="py-20 px-6">
    <div class="max-w-xl mx-auto text-center">
      <div class="text-6xl mb-6">🎉</div>
      
      <h1 class="text-4xl font-bold mb-4">Payment Successful!</h1>
      
      <p class="text-xl text-slate-400 mb-8">
        Thank you for purchasing the Zero Method AI Prompts Starter Pack.
      </p>

      <div class="bg-slate-800 rounded-2xl p-8 border border-slate-700 mb-8">
        <div class="flex items-center justify-center gap-3 mb-6">
          <span class="w-12 h-12 bg-cyan-400/20 rounded-full flex items-center justify-center text-cyan-400">✓</span>
        </div>

        <h2 class="text-xl font-semibold mb-4">Check Your Inbox</h2>
        
        <p class="text-slate-400 mb-6">
          We've sent a download link to your email address. 
          It may take a few minutes to arrive.
        </p>

        <div class="p-4 bg-slate-900/50 rounded-lg text-left">
          <p class="text-sm text-slate-500 mb-2"><strong>What happens next:</strong></p>
          <ul class="text-sm text-slate-400 space-y-2">
            <li class="flex items-start gap-2">
              <span class="text-cyan-400">1.</span>
              <span>Check your email for the download link</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-cyan-400">2.</span>
              <span>Click the download button in the email</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-cyan-400">3.</span>
              <span>Unzip the file and start using your prompts</span>
            </li>
          </ul>
        </div>
      </div>

      <p class="text-slate-500 mb-6">
        Didn't receive the email? Check your spam folder or 
        <a href="mailto:support@thezeromethod.com" class="text-cyan-400 hover:underline">contact support</a>.
      </p>

      <a 
        href="/"
        class="inline-block px-8 py-4 bg-slate-700 rounded-lg font-semibold text-white hover:bg-slate-600 transition"
      >
        Back to Home
      </a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-8 px-6 border-t border-slate-800">
    <div class="max-w-6xl mx-auto text-center text-slate-500">
      <p>© 2026 Zero Method. Built with ◈.</p>
    </div>
  </footer>
</Layout>