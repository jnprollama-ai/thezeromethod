---
export interface Props {
  variant?: 'default' | 'gold' | 'green' | 'red';
  size?: 'sm' | 'md';
  pulse?: boolean;
  class?: string;
}

const { 
  variant = 'default', 
  size = 'sm',
  pulse = false,
  class: className = ''
} = Astro.props;

const baseStyles = 'inline-flex items-center gap-1.5 font-medium rounded-full transition-colors';

const variantStyles = {
  default: 'bg-slate-700 text-slate-300 border border-slate-600',
  gold: 'bg-amber-500/20 text-amber-400 border border-amber-500/30',
  green: 'bg-green-500/20 text-green-400 border border-green-500/30',
  red: 'bg-red-500/20 text-red-400 border border-red-500/30'
};

const sizeStyles = {
  sm: 'px-2.5 py-0.5 text-xs',
  md: 'px-3 py-1 text-sm'
};

const pulseDot = pulse ? '<span class="w-1.5 h-1.5 rounded-full bg-current animate-pulse"></span>' : '';

const classes = `${baseStyles} ${variantStyles[variant]} ${sizeStyles[size]} ${className}`;
---

<span class={classes}>
  {pulse && <span class="w-1.5 h-1.5 rounded-full bg-current animate-pulse"></span>}
  <slot />
</span>