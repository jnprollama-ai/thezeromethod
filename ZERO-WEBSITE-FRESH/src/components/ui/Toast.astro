---
export interface Props {
  variant?: 'default' | 'success' | 'error' | 'warning' | 'info';
  title?: string;
  duration?: number;
  dismissible?: boolean;
  class?: string;
}

const { 
  variant = 'default', 
  title,
  duration,
  dismissible = true,
  class: className = ''
} = Astro.props;

const baseStyles = 'fixed bottom-6 right-6 z-50 max-w-md w-full mx-4 p-4 rounded-xl border shadow-xl animate-slideUp';

const variantStyles = {
  default: 'bg-slate-800 border-slate-700 text-slate-100',
  success: 'bg-green-900/90 border-green-500/50 text-green-100',
  error: 'bg-red-900/90 border-red-500/50 text-red-100',
  warning: 'bg-amber-900/90 border-amber-500/50 text-amber-100',
  info: 'bg-blue-900/90 border-blue-500/50 text-blue-100'
};

const iconStyles = {
  default: '',
  success: 'text-green-400',
  error: 'text-red-400',
  warning: 'text-amber-400',
  info: 'text-blue-400'
};

const icons = {
  default: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  success: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  error: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  warning: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>`,
  info: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`
};

const classes = `${baseStyles} ${variantStyles[variant]} ${className}`;
---

<div 
  class={classes} 
  role="alert"
  data-duration={duration}
  data-toast
>
  <div class="flex items-start gap-3">
    <div class={`flex-shrink-0 ${iconStyles[variant]}`}>
      <Fragment set:html={icons[variant]} />
    </div>
    
    <div class="flex-1 min-w-0">
      {title && (
        <h4 class="font-semibold text-sm mb-1">{title}</h4>
      )}
      <div class="text-sm opacity-90">
        <slot />
      </div>
    </div>
    
    {dismissible && (
      <button 
        type="button"
        class="flex-shrink-0 -mr-1 -mt-1 p-1 rounded-lg opacity-60 hover:opacity-100 hover:bg-white/10 transition-opacity"
        aria-label="Dismiss"
        data-dismiss
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    )}
  </div>
  
  {duration && (
    <div class="mt-3 h-1 bg-white/20 rounded-full overflow-hidden">
      <div 
        class="h-full bg-current opacity-50 origin-left"
        data-progress
        style={`animation: shrink ${duration}ms linear forwards`}
      />
    </div>
  )}
</div>

<style>
  @keyframes shrink {
    from { transform: scaleX(1); }
    to { transform: scaleX(0); }
  }
  
  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .animate-slideUp {
    animation: slideUp 0.3s ease-out;
  }
</style>

<script>
  document.querySelectorAll('[data-toast]').forEach(toast => {
    const duration = toast.dataset.duration;
    const dismissBtn = toast.querySelector('[data-dismiss]');
    
    if (dismissBtn) {
      dismissBtn.addEventListener('click', () => {
        toast.style.opacity = '0';
        toast.style.transform = 'translateY(20px)';
        setTimeout(() => toast.remove(), 300);
      });
    }
    
    if (duration) {
      setTimeout(() => {
        toast.style.opacity = '0';
        toast.style.transform = 'translateY(20px)';
        setTimeout(() => toast.remove(), 300);
      }, parseInt(duration));
    }
  });
</script>