---
export interface Props {
  type?: 'text' | 'email' | 'password' | 'number' | 'search' | 'tel' | 'url';
  name?: string;
  id?: string;
  label?: string;
  placeholder?: string;
  value?: string;
  required?: boolean;
  disabled?: boolean;
  readonly?: boolean;
  autocomplete?: string;
  class?: string;
  labelClass?: string;
  inputClass?: string;
  error?: string;
  helper?: string;
}

const { 
  type = 'text',
  name,
  id,
  label,
  placeholder,
  value,
  required = false,
  disabled = false,
  readonly = false,
  autocomplete,
  class: className = '',
  labelClass = '',
  inputClass = '',
  error,
  helper
} = Astro.props;

const inputId = id || name || Math.random().toString(36).substr(2, 9);

const inputBaseStyles = 'w-full px-4 py-3 bg-slate-800 border rounded-lg text-slate-100 placeholder-slate-500 transition-all duration-250 focus:outline-none focus:ring-2 focus:ring-cyan-400/50 focus:border-cyan-400 disabled:opacity-50 disabled:cursor-not-allowed disabled:bg-slate-900';

const inputStateStyles = error 
  ? 'border-red-500 focus:border-red-500 focus:ring-red-400/50' 
  : 'border-slate-700 hover:border-slate-600 focus:border-cyan-400';

const inputClasses = `${inputBaseStyles} ${inputStateStyles} ${inputClass}`;
---

<div class={`space-y-2 ${className}`}>
  {label && (
    <label 
      for={inputId} 
      class={`block text-sm font-medium text-slate-300 ${labelClass}`}
    >
      {label}
      {required && <span class="text-red-400 ml-1">*</span>}
    </label>
  )}
  
  <input
    type={type}
    name={name}
    id={inputId}
    placeholder={placeholder}
    value={value}
    required={required}
    disabled={disabled}
    readonly={readonly}
    autocomplete={autocomplete}
    class={inputClasses}
    aria-invalid={error ? 'true' : 'false'}
    aria-describedby={error ? `${inputId}-error` : helper ? `${inputId}-helper` : undefined}
  />
  
  {error && (
    <p id={`${inputId}-error`} class="text-sm text-red-400 flex items-center gap-1">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      {error}
    </p>
  )}
  
  {helper && !error && (
    <p id={`${inputId}-helper`} class="text-sm text-slate-500">{helper}</p>
  )}
</div>