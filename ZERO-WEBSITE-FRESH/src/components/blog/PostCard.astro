---
export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  author: string;
  tags?: string[];
  slug: string;
  featured?: boolean;
}

const { title, description, pubDate, author, tags = [], slug, featured = false } = Astro.props;

const formattedDate = new Date(pubDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
});
---

<article class:list={[
  "group cursor-pointer",
  featured ? "md:col-span-2 md:row-span-2" : ""
]}>
  <a href={`/blog/${slug}`} class="block h-full">
    <div class:list={[
      "h-full bg-slate-900/50 border border-slate-800 rounded-xl overflow-hidden transition-all duration-300",
      "hover:border-emerald-500/50 hover:bg-slate-800/50",
      featured ? "p-6 md:p-8" : "p-5"
    ]}>
      {/* Tags */}
      <div class="flex flex-wrap gap-2 mb-3">
        {tags.slice(0, featured ? 3 : 2).map((tag) => (
          <span class="px-2.5 py-1 text-xs font-medium bg-emerald-500/10 text-emerald-400 rounded-full">
            {tag}
          </span>
        ))}
      </div>

      {/* Title */}
      <h3 class:list={[
        "font-bold text-white leading-tight mb-2 group-hover:text-emerald-400 transition-colors",
        featured ? "text-2xl md:text-3xl" : "text-lg"
      ]}>
        {title}
      </h3>

      {/* Description */}
      <p class:list={[
        "text-slate-400 leading-relaxed mb-4",
        featured ? "text-base md:text-lg line-clamp-3" : "text-sm line-clamp-2"
      ]}>
        {description}
      </p>

      {/* Meta */}
      <div class="flex items-center gap-3 text-xs text-slate-500 mt-auto">
        <span class="font-medium text-slate-400">{author}</span>
        <span class="text-slate-600">•</span>
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
      </div>
    </div>
  </a>
</article>