---
export interface Props {
  showNewsletter?: boolean;
  class?: string;
}

const { 
  showNewsletter = true,
  class: className = ''
} = Astro.props;
---

<footer class={`bg-slate-900 border-t border-slate-800 py-12 px-4 sm:px-6 lg:px-8 ${className}`}>
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
      <!-- Column 1: Brand -->
      <div class="space-y-4">
        <a 
          href="/" 
          class="text-xl font-bold bg-gradient-to-r from-cyan-400 to-purple-500 bg-clip-text text-transparent inline-block"
        >
          ◈ Zero Method
        </a>
        <p class="text-slate-400 text-sm leading-relaxed">
          AI prompts and templates that save you hours every week. Built for busy professionals.
        </p>
        
        <div class="flex gap-4">
          <a 
            href="https://twitter.com/ZeroMethodAI" 
            target="_blank"
            rel="noopener noreferrer"
            class="text-slate-400 hover:text-cyan-400 transition-colors"
            aria-label="Twitter"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a 
            href="#" 
            class="text-slate-400 hover:text-purple-400 transition-colors"
            aria-label="GitHub"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
        </div>
      </div>
      
      <!-- Column 2: Product -->
      <div class="space-y-4">
        <h3 class="font-semibold text-slate-100">Product</h3>
        <ul class="space-y-2">
          <li>
            <a href="/product" class="text-slate-400 hover:text-white transition-colors text-sm">AI Prompt Pack</a>
          </li>
          <li>
            <a href="#features" class="text-slate-400 hover:text-white transition-colors text-sm">Features</a>
          </li>
          <li>
            <a href="#pricing" class="text-slate-400 hover:text-white transition-colors text-sm">Pricing</a>
          </li>
          <li>
            <a href="#faq" class="text-slate-400 hover:text-white transition-colors text-sm">FAQ</a>
          </li>
        </ul>
      </div>
      
      <!-- Column 3: Company -->
      <div class="space-y-4">
        <h3 class="font-semibold text-slate-100">Company</h3>
        <ul class="space-y-2">
          <li>
            <a href="/blog" class="text-slate-400 hover:text-white transition-colors text-sm">Blog</a>
          </li>
          <li>
            <a href="/privacy" class="text-slate-400 hover:text-white transition-colors text-sm">Privacy</a>
          </li>
          <li>
            <a href="/terms" class="text-slate-400 hover:text-white transition-colors text-sm">Terms</a>
          </li>
          <li>
            <a href="mailto:support@thezeromethod.com" class="text-slate-400 hover:text-white transition-colors text-sm">Contact</a>
          </li>
        </ul>
      </div>
    </div>
    
    <!-- Bottom Bar -->
    <div class="mt-12 pt-8 border-t border-slate-800">
      <div class="flex flex-col sm:flex-row justify-between items-center gap-4">
        <p class="text-slate-500 text-sm">
          © {new Date().getFullYear()} Zero Method. Built with ◈.
        </p>
        <div class="flex items-center gap-4">
          <a href="/privacy" class="text-slate-500 hover:text-slate-400 text-sm transition-colors">Privacy</a>
          <a href="/terms" class="text-slate-500 hover:text-slate-400 text-sm transition-colors">Terms</a>
        </div>
      </div>
    </div>
  </div>
</footer>