---
export interface Props {
  sticky?: boolean;
  transparent?: boolean;
  class?: string;
}

const { 
  sticky = true,
  transparent = false,
  class: className = ''
} = Astro.props;

const baseStyles = 'w-full py-4 px-4 sm:px-6 lg:px-8 transition-all duration-300';
const stickyStyles = sticky ? 'fixed top-0 left-0 right-0 z-50' : 'relative';
const bgStyles = transparent 
  ? 'bg-transparent' 
  : 'bg-slate-900/80 backdrop-blur-md border-b border-slate-800';

const classes = `${baseStyles} ${stickyStyles} ${bgStyles} ${className}`;
---

<header class={classes} data-header>
  <div class="max-w-6xl mx-auto flex items-center justify-between">
    <div class="flex items-center">
      <a 
        href="/" 
        class="text-xl font-bold bg-gradient-to-r from-cyan-400 to-purple-500 bg-clip-text text-transparent hover:opacity-80 transition-opacity"
        aria-label="Zero Method Home"
      >
        ◈ Zero Method
      </a>
    </div>
    
    <nav class="hidden md:flex items-center gap-8" aria-label="Main navigation">
      <a 
        href="/" 
        class="text-slate-300 hover:text-white transition-colors font-medium"
      >
        Home
      </a>
      <a 
        href="/product" 
        class="text-slate-300 hover:text-white transition-colors font-medium"
      >
        Product
      </a>
      <a 
        href="/blog" 
        class="text-slate-300 hover:text-white transition-colors font-medium"
      >
        Blog
      </a>
    </nav>
    
    <!-- Mobile Menu Button -->
    <button 
      type="button"
      class="md:hidden p-2 rounded-lg text-slate-400 hover:text-white hover:bg-slate-800 transition-colors"
      aria-label="Toggle menu"
      aria-expanded="false"
      data-menu-toggle
    >
      <svg 
        class="w-6 h-6 menu-open" 
        fill="none" 
        stroke="currentColor" 
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
      <svg 
        class="w-6 h-6 menu-close hidden" 
        fill="none" 
        stroke="currentColor" 
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>
  
  <!-- Mobile Navigation -->
  <nav 
    class="md:hidden hidden absolute top-full left-0 right-0 bg-slate-900/95 backdrop-blur-md border-b border-slate-800 py-4 px-4 sm:px-6"
    aria-label="Mobile navigation"
    data-mobile-menu
  >
    <div class="flex flex-col gap-4">
      <a 
        href="/" 
        class="text-slate-300 hover:text-white transition-colors font-medium py-2"
      >
        Home
      </a>
      <a 
        href="/product" 
        class="text-slate-300 hover:text-white transition-colors font-medium py-2"
      >
        Product
      </a>
      <a 
        href="/blog" 
        class="text-slate-300 hover:text-white transition-colors font-medium py-2"
      >
        Blog
      </a>
    </div>
  </nav>
</header>

{sticky && <div class="h-16 md:h-16" aria-hidden="true"></div>}

<script>
  // Mobile menu toggle
  const menuToggle = document.querySelector('[data-menu-toggle]');
  const mobileMenu = document.querySelector('[data-mobile-menu]');
  const menuOpen = document.querySelector('.menu-open');
  const menuClose = document.querySelector('.menu-close');
  
  if (menuToggle && mobileMenu) {
    menuToggle.addEventListener('click', () => {
      const isExpanded = menuToggle.getAttribute('aria-expanded') === 'true';
      menuToggle.setAttribute('aria-expanded', !isExpanded);
      mobileMenu.classList.toggle('hidden');
      menuOpen?.classList.toggle('hidden');
      menuClose?.classList.toggle('hidden');
    });
  }
  
  // Scroll behavior - add shadow when scrolled
  const header = document.querySelector('[data-header]');
  if (header) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 10) {
        header.classList.add('shadow-lg', 'shadow-black/20');
      } else {
        header.classList.remove('shadow-lg', 'shadow-black/20');
      }
    });
  }
</script>