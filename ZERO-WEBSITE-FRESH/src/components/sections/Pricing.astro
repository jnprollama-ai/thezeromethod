---
import Card from '../ui/Card.astro';
import Button from '../ui/Button.astro';
import Badge from '../ui/Badge.astro';

export interface Props {
  title?: string;
  subtitle?: string;
  tiers: Array<{
    name: string;
    description: string;
    price: number;
    interval?: string;
    features: string[];
    cta: {
      text: string;
      href: string;
    };
    popular?: boolean;
    badge?: string;
  }>;
}

const { 
  title = "Simple Pricing",
  subtitle = "One-time payment. No subscriptions.",
  tiers
} = Astro.props;
---

<section id="pricing" class="py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">{title}</h2>
      {subtitle && <p class="text-lg text-slate-400">{subtitle}</p>}
    </div>
    
    <!-- Pricing Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {tiers.map((tier) => (
        <Card 
          variant={tier.popular ? 'glow' : 'elevated'} 
          padding="lg"
          class={tier.popular ? 'ring-2 ring-cyan-400/50 relative' : ''}
        >
          <!-- Popular Badge -->
          {tier.popular && (
            <div class="absolute -top-4 left-1/2 -translate-x-1/2">
              <Badge variant="gold" size="md">
                {tier.badge || 'Most Popular'}
              </Badge>
            </div>
          )}
          
          <!-- Tier Header -->
          <div class="text-center mb-6">
            <h3 class="text-xl font-bold text-slate-100 mb-2">{tier.name}</h3>
            <p class="text-slate-400 text-sm mb-4">{tier.description}</p>
            
            <div class="flex items-baseline justify-center gap-1">
              <span class="text-slate-400">$</span>
              <span class="text-5xl font-bold">{tier.price}</span>
              {tier.interval && <span class="text-slate-400">{tier.interval}</span>}
            </div>
          </div>
          
          <!-- Features -->
          <ul class="space-y-3 mb-8">
            {tier.features.map((feature) => (
              <li class="flex items-start gap-3">
                <svg 
                  class="w-5 h-5 text-cyan-400 flex-shrink-0 mt-0.5" 
                  fill="none" 
                  stroke="currentColor" 
                  viewBox="0 0 24 24"
                >
                  <path 
                    stroke-linecap="round" 
                    stroke-linejoin="round" 
                    stroke-width="2" 
                    d="M5 13l4 4L19 7" 
                  />
                </svg>
                <span class="text-slate-300">{feature}</span>
              </li>
            ))}
          </ul>
          
          <!-- CTA -->
          <Button 
            href={tier.cta.href}
            variant={tier.popular ? 'primary' : 'ghost'}
            class="w-full"
            size="lg"
          >
            {tier.cta.text}
          </Button>
        </Card>
      ))}
    </div>
    
    <!-- Trust Badge -->
    <div class="mt-12 text-center">
      <p class="text-slate-500 text-sm flex items-center justify-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        30-day money-back guarantee
      </p>
    </div>
  </div>
</section>