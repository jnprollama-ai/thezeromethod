{
  "name": "zero-command-center-pro",
  "version": "4.0.0",
  "description": "Production-ready Command Center with JWT auth, trading module, and live metrics",
  "main": "server-v4.js",
  "scripts": {
    "start": "node server-v4.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server-v4.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "deploy": "./scripts/deploy.sh",
    "healthcheck": "node healthcheck.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "cors": "^2.8.5",
    "uuid": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}