{
  "name": "zero-command-center",
  "version": "4.0.0",
  "description": "Unified Command Center with auto-update",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "update": "git pull origin main && npm install && pm2 restart server.js",
    "status": "node -e \"console.log('Check http://localhost:3456/api/status')\""
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "cors": "^2.8.5",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}