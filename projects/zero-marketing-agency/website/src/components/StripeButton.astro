---
interface Props {
  priceId: string;
  price: string; // Price in USD (e.g., "19.00")
  productName: string; // Name of the product
  buttonText?: string;
  class?: string;
}

const { priceId, price, productName, buttonText = "Get Started", class: className = "" } = Astro.props;

// Check if running in production
const isProduction = import.meta.env.PROD;
const stripeKey = import.meta.env.STRIPE_PUBLISHABLE_KEY || '';
const paypalClientId = import.meta.env.PAYPAL_CLIENT_ID || '';

// Determine which payment processor to use (prefer Stripe if both are configured)
// For development/testing, we'll show PayPal if it's configured and Stripe isn't
const useStripe = isProduction && stripeKey;
const usePayPal = paypalClientId && (!stripeKey || !isProduction);
const showComingSoon = !useStripe && !usePayPal;
---

<div>
  {useStripe ? (
    <button
      class={`stripe-checkout-btn ${className}`}
      data-price-id={priceId}
      type="button"
    >
      {buttonText} with Card
    </button>
  ) : usePayPal ? (
    <button
      class={`paypal-checkout-btn ${className}`}
      data-price={price}
      data-product={productName}
      type="button"
    >
      {buttonText} with PayPal
    </button>
  ) : (
    <a
      href="mailto:support@thezeromethod.com?subject=Interested%20in%20Zero%20Method%20Starter%20Pack"
      class={className}
    >
      {buttonText} (Coming Soon)
    </a>
  )}

  {/* Container for PayPal buttons */}
  <div id="paypal-button-container" class="mt-4"></div>
</div>

{
  useStripe && (
    <script define:vars={{ stripeKey }}>
      // Stripe integration script
      const btn = document.querySelector('.stripe-checkout-btn');
      if (btn) {
        btn.addEventListener('click', async () => {
          try {
            const stripe = await loadStripe(stripeKey);
            const priceId = btn.getAttribute('data-price-id');
            
            const response = await fetch('/api/create-checkout-session', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
              },
              body: JSON.stringify({
                priceId: priceId,
                successUrl: `${window.location.origin}/success`,
                cancelUrl: `${window.location.origin}/cancel`,
              }),
            });
            
            const session = await response.json();
            
            if (session.id) {
              await stripe.redirectToCheckout({ sessionId: session.id });
            } else {
              alert('Something went wrong. Please try again or contact support.');
            }
          } catch (error) {
            console.error('Stripe error:', error);
            alert('Payment system not configured yet. Email us at support@thezeromethod.com');
          }
        });
      }
      
      // Load Stripe.js
      function loadStripe(key) {
        return new Promise((resolve, reject) => {
          if (window.Stripe) {
            resolve(window.Stripe(key));
            return;
          }
          const script = document.createElement('script');
          script.src = 'https://js.stripe.com/v3/';
          script.onload = () => resolve(window.Stripe(key));
          script.onerror = reject;
          document.head.appendChild(script);
        });
      }
    </script>
  )
}

{
  usePayPal && (
    <script define:vars={{ paypalClientId }}>
      // PayPal integration script
      const btn = document.querySelector('.paypal-checkout-btn');
      if (btn) {
        btn.addEventListener('click', async () => {
          try {
            // Load PayPal SDK and initialize payment
            const paypal = await loadPayPalSDK(paypalClientId);
            
            // Render the PayPal buttons
            paypal.Buttons({
              createOrder: function(data, actions) {
                return actions.order.create({
                  purchase_units: [{
                    amount: {
                      value: btn.getAttribute('data-price')
                    }
                  }]
                });
              },
              onApprove: function(data, actions) {
                return actions.order.capture().then(function(details) {
                  // Redirect to success page with payment details
                  window.location.href = `/success?paymentId=${details.id}&payerId=${details.payer.payer_id}`;
                });
              },
              onError: function(err) {
                console.error('PayPal error:', err);
                alert('Payment failed. Please try again or contact support.');
              }
            }).render('#paypal-button-container');
          } catch (error) {
            console.error('PayPal error:', error);
            alert('Payment system not configured yet. Email us at support@thezeromethod.com');
          }
        });
      }
      
      // Load PayPal SDK
      function loadPayPalSDK(clientId) {
        return new Promise((resolve, reject) => {
          if (window.paypal) {
            resolve(window.paypal);
            return;
          }
          const script = document.createElement('script');
          script.src = `https://www.paypal.com/sdk/js?client-id=${clientId}&currency=USD`;
          script.onload = () => resolve(window.paypal);
          script.onerror = reject;
          document.head.appendChild(script);
        });
      }
    </script>
  )
}
