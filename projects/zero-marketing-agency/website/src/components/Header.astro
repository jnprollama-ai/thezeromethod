---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/product', label: 'Product' },
  { href: '/blog', label: 'Blog' },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50" style="background-color: rgba(8, 12, 20, 0.9); backdrop-filter: blur(10px); border-bottom: 1px solid var(--border);"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center space-x-2">
        <div class="w-8 h-8 lg:w-10 lg:h-10 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, var(--gold), var(--gold-dim));"
        >
          <span class="font-bold text-lg lg:text-xl" style="color: var(--bg);"
          >0</span>
        </div>
        <span class="font-display text-xl lg:text-2xl font-bold" style="color: var(--text);"
        >
          Zero<span style="color: var(--gold);">Method</span>
        </span>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center space-x-8">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              "text-sm font-medium transition-colors duration-200",
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? "nav-active"
                : "nav-inactive"
            ]}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- CTA Button -->
      <div class="hidden md:block">
        <a
          href="/product"
          class="inline-flex items-center px-5 py-2.5 font-semibold text-sm rounded-lg transition-colors duration-200"
          style="background-color: var(--gold); color: var(--bg);"
          onmouseover="this.style.backgroundColor='var(--gold-dim)';"
          onmouseout="this.style.backgroundColor='var(--gold)';"
          target="_blank"
          rel="noopener"
        >
          Get Started
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2"
        style="color: var(--text-muted);"
        aria-label="Toggle menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden py-4" style="border-top: 1px solid var(--border);"
    >
      <nav class="flex flex-col space-y-4">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              "text-base font-medium transition-colors duration-200",
              currentPath === link.href
                ? "nav-active"
                : "nav-inactive"
            ]}
          >
            {link.label}
          </a>
        ))}
        <a
          href="/product"
          class="inline-flex items-center justify-center px-5 py-3 font-semibold text-sm rounded-lg transition-colors duration-200"
          style="background-color: var(--gold); color: var(--bg);"
          target="_blank"
          rel="noopener"
        >
          Get Started
        </a>
      </nav>
    </div>
  </div>
</header>

<style>
  .nav-active {
    color: var(--gold);
  }
  
  .nav-inactive {
    color: var(--text-muted);
  }
  
  .nav-inactive:hover {
    color: var(--text);
  }
  
  #mobile-menu-btn:hover {
    color: var(--text) !important;
  }
</style>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>