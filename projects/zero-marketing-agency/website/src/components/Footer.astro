---
const currentYear = new Date().getFullYear();

const footerLinks = {
  product: [
    { href: '/product', label: 'Features' },
    { href: '/product#pricing', label: 'Pricing' },
    { href: '/product#faq', label: 'FAQ' },
  ],
  company: [
    { href: '/blog', label: 'Blog' },
    { href: 'mailto:support@thezeromethod.com', label: 'Contact', external: false },
  ],
  legal: [
    { href: '/privacy', label: 'Privacy Policy' },
    { href: '/terms', label: 'Terms of Service' },
    { href: '/license', label: 'License' },
  ],
};

// Social links with X (Twitter) active
const socialLinks = [
  {
    name: 'X (Twitter)',
    href: 'https://x.com/ZeroMethodAI',
    external: true,
  },
];
---

<footer style="background-color: var(--surface); border-top: 1px solid var(--border);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <a href="/" class="flex items-center space-x-2 mb-4">
          <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, var(--gold), var(--gold-dim));"
          >
            <span class="font-bold text-xl" style="color: var(--bg);">0</span>
          </div>
          <span class="font-display text-2xl font-bold" style="color: var(--text);"
          >
            Zero<span style="color: var(--gold);">Method</span>
          </span>
        </a>
        <p class="text-sm leading-relaxed mb-6 max-w-sm" style="color: var(--text-muted);">
          25 AI prompts + 10 email templates. Copy-paste ready resources that save you 5 hours every week.
        </p>
        
        <!-- Social Links -->
        <div class="flex items-center space-x-4">
          {socialLinks.map(link => (
            <a
              href={link.href}
              class="text-sm transition-colors hover:text-[var(--gold)]"
              style="color: var(--text-muted);"
              target="_blank"
              rel="noopener"
              aria-label={link.name}
            >
              {link.name}
            </a>
          ))}
        </div>
      </div>

      <!-- Links -->
      <div>
        <h3 class="font-semibold mb-4" style="color: var(--text);">Product</h3>
        <ul class="space-y-3">
          {footerLinks.product.map(link => (
            <li>
              <a 
                href={link.href} 
                class="text-sm transition-colors duration-200 hover:text-[var(--gold)]"
                style="color: var(--text-muted);"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="font-semibold mb-4" style="color: var(--text);">Company</h3>
        <ul class="space-y-3">
          {footerLinks.company.map(link => (
            <li>
              <a 
                href={link.href} 
                class="text-sm transition-colors duration-200 hover:text-[var(--gold)]"
                style="color: var(--text-muted);"
                {...(link.external && { target: "_blank", rel: "noopener" })}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="font-semibold mb-4" style="color: var(--text);">Legal</h3>
        <ul class="space-y-3">
          {footerLinks.legal.map(link => (
            <li>
              <a 
                href={link.href} 
                class="text-sm transition-colors duration-200 hover:text-[var(--gold)]"
                style="color: var(--text-muted);"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="mt-12 pt-8" style="border-top: 1px solid var(--border);"
    >
      <div class="flex flex-col md:flex-row items-center justify-between space-y-4 md:space-y-0">
        <p class="text-sm" style="color: var(--text-muted);">
          © {currentYear} Zero Method. All rights reserved.
        </p>
        <p class="text-xs" style="color: var(--text-muted); opacity: 0.7;">
          Built with <span style="color: var(--gold);"></span> by Zero
        </p>
      </div>
    </div>
  </div>
</footer>