---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';

const title = "Zero Method | The AI Productivity Suite";
const description = "Save 10+ hours every week with battle-tested AI prompts and proven productivity templates. Join 5,000+ professionals who've transformed their workflow.";

const features = [
  {
    title: "Time-Saving Prompts",
    description: "Over 150+ proven prompts that eliminate busywork and automate repetitive tasks across every tool you use.",
    icon: "⚡"
  },
  {
    title: "Done-For-You Templates",
    description: "Professionally designed templates for ChatGPT, Claude, Midjourney, and more. Copy, paste, and get results instantly.",
    icon: "📋"
  },
  {
    title: "Real ROI",
    description: "Average user reports saving 10+ hours per week. That means the suite pays for itself in the first day.",
    icon: "💰"
  }
];

const testimonials = [
  {
    quote: "The prompt templates alone saved me 12 hours in my first week. I was skeptical, but this is the real deal.",
    author: "Sarah Chen",
    role: "Marketing Director, Tech Startup",
    avatar: "SC"
  },
  {
    quote: "I finally understand how to use AI effectively. My productivity has 10x'd and my team thinks I'm a wizard.",
    author: "Marcus Rodriguez",
    role: "Freelance Consultant",
    avatar: "MR"
  },
  {
    quote: "Worth every penny. The agency package transformed how we deliver client work. Turnaround time cut in half.",
    author: "Jennifer Walsh",
    role: "Agency Owner",
    avatar: "JW"
  }
];
---

<Layout title={title} description={description}>
  <Header />

  <main>
    <!-- Hero Section -->
    <section class="relative pt-32 pb-20 lg:pt-40 lg:pb-32 overflow-hidden">
      <!-- Background gradient -->
      <div class="absolute inset-0 bg-gradient-to-b from-navy-900/50 via-navy-950 to-navy-950"></div>
      
      <div class="relative max-w-7xl mx-auto px-6 lg:px-8">
        <div class="text-center max-w-4xl mx-auto">
          <!-- Badge -->
          <div class="inline-flex items-center px-4 py-2 rounded-full bg-gold-500/10 border border-gold-500/20 mb-8">
            <span class="w-2 h-2 rounded-full bg-gold-500 mr-2"></span>
            <span class="text-gold-400 text-sm font-medium">New: AI Workflow Playbook 2.0</span>
          </div>

          <!-- Headline -->
          <h1 class="text-4xl sm:text-5xl lg:text-7xl font-bold text-white leading-tight mb-6">
            The AI Prompts That Save
            <span class="bg-gradient-to-r from-gold-400 to-gold-600 bg-clip-text text-transparent">10 Hours a Week</span>
          </h1>

          <!-- Subhead -->
          <p class="text-lg sm:text-xl text-navy-300 mb-10 max-w-2xl mx-auto leading-relaxed">
            Join 5,000+ professionals who've transformed their workflow with battle-tested prompts, done-for-you templates, and proven AI strategies.
          </p>

          <!-- CTA Buttons -->
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12">
            <a
              href="/product"
              class="inline-flex items-center px-8 py-4 bg-gold-500 hover:bg-gold-600 text-navy-900 font-bold text-lg rounded-lg transition-all duration-200 hover:shadow-lg hover:shadow-gold-500/20"
            >
              Get the Full Suite
              <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
            <a
              href="#free-prompts"
              class="inline-flex items-center px-8 py-4 bg-navy-800 hover:bg-navy-700 text-white font-semibold text-lg rounded-lg transition-colors duration-200 border border-navy-700"
            >
              Get 5 Free Prompts
            </a>
          </div>

          <!-- Social Proof -->
          <div class="flex items-center justify-center space-x-6 text-navy-400 text-sm">
            <div class="flex items-center">
              <svg class="w-5 h-5 text-gold-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span>5,000+ Users</span>
            </div>
            <div class="flex items-center">
              <svg class="w-5 h-5 text-gold-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span>150+ Templates</span>
            </div>
            <div class="flex items-center">
              <svg class="w-5 h-5 text-gold-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span>4.9/5 Rating</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Problem Section -->
    <section class="py-20 bg-navy-900/50">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="max-w-3xl mx-auto text-center mb-16">
          <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
            Sound Familiar?
          </h2>
          <p class="text-navy-400 text-lg">
            You're busy. We get it. But are you actually productive?
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="p-8 bg-navy-800/50 rounded-2xl border border-navy-700">
            <div class="w-12 h-12 rounded-xl bg-red-500/10 flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-white mb-3">Drowning in Busywork</h3>
            <p class="text-navy-400">
              Hours wasted on emails, reports, and repetitive tasks that should've been automated months ago.
            </p>
          </div>

          <div class="p-8 bg-navy-800/50 rounded-2xl border border-navy-700">
            <div class="w-12 h-12 rounded-xl bg-orange-500/10 flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-white mb-3">AI Confusion</h3>
            <p class="text-navy-400">
              Everyone's talking about AI, but you don't know where to start. Prompts feel like guesswork.
            </p>
          </div>

          <div class="p-8 bg-navy-800/50 rounded-2xl border border-navy-700">
            <div class="w-12 h-12 rounded-xl bg-yellow-500/10 flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-white mb-3">Inconsistent Results</h3>
            <p class="text-navy-400">
              When you do try AI, the output is hit-or-miss. No system, no consistency, no time saved.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Solution Section -->
    <section class="py-20">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="max-w-3xl mx-auto text-center mb-16">
          <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
            Here's a Better Way
          </h2>
          <p class="text-navy-400 text-lg">
            Everything you need to turn AI into your personal productivity engine.
          </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
          {features.map(feature => (
            <div class="group p-8 bg-navy-900 rounded-2xl border border-navy-800 hover:border-gold-500/50 transition-colors duration-300">
              <div class="text-4xl mb-6">{feature.icon}</div>
              <h3 class="text-xl font-semibold text-white mb-4">{feature.title}</h3>
              <p class="text-navy-400 leading-relaxed">{feature.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Email Capture Section -->
    <section id="free-prompts" class="py-20 bg-navy-900/50">
      <div class="max-w-4xl mx-auto px-6 lg:px-8">
        <div class="bg-gradient-to-br from-navy-800 to-navy-900 rounded-3xl p-8 lg:p-12 border border-navy-700">
          <div class="text-center mb-8">
            <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
              Get 5 Free Prompts
            </h2>
            <p class="text-navy-400 text-lg max-w-xl mx-auto">
              Try our most popular prompts before you buy. These 5 templates alone will save you hours this week.
            </p>
          </div>

          <form class="max-w-md mx-auto" action="#" method="POST">
            <div class="flex flex-col sm:flex-row gap-4">
              <input
                type="email"
                name="email"
                placeholder="Enter your email"
                required
                class="flex-1 px-5 py-4 bg-navy-950 border border-navy-700 rounded-lg text-white placeholder-navy-500 focus:outline-none focus:ring-2 focus:ring-gold-500 focus:border-transparent"
              />
              <button
                type="submit"
                class="px-8 py-4 bg-gold-500 hover:bg-gold-600 text-navy-900 font-bold rounded-lg transition-colors duration-200 whitespace-nowrap"
              >
                Send Me Prompts
              </button>
            </div>
            <p class="text-navy-500 text-sm mt-4 text-center">
              No spam. Unsubscribe anytime. Join 5,000+ professionals.
            </p>
          </form>
        </div>
      </div>
    </section>

    <!-- Social Proof Section -->
    <section class="py-20">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="max-w-3xl mx-auto text-center mb-16">
          <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
            What Professionals Are Saying
          </h2>
          <p class="text-navy-400 text-lg">
            Join thousands who've transformed their productivity.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {testimonials.map(testimonial => (
            <div class="p-8 bg-navy-900 rounded-2xl border border-navy-800">
              <div class="flex items-center mb-4">
                <div class="flex text-gold-500">
                  {[...Array(5)].map(() => (
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                  ))}
                </div>
              </div>
              <blockquote class="text-white text-lg mb-6 leading-relaxed">
                "{testimonial.quote}"
              </blockquote>
              <div class="flex items-center">
                <div class="w-12 h-12 rounded-full bg-gradient-to-br from-gold-400 to-gold-600 flex items-center justify-center text-navy-900 font-bold text-sm">
                  {testimonial.avatar}
                </div>
                <div class="ml-4">
                  <p class="text-white font-medium">{testimonial.author}</p>
                  <p class="text-navy-400 text-sm">{testimonial.role}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Final CTA Section -->
    <section class="py-20 bg-navy-900/50">
      <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center">
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-6">
          Ready to Reclaim 10 Hours Every Week?
        </h2>
        <p class="text-navy-400 text-lg mb-10 max-w-2xl mx-auto">
          Get instant access to 150+ proven prompts, done-for-you templates, and our complete AI productivity system.
        </p>
        <a
          href="/product"
          class="inline-flex items-center px-10 py-5 bg-gold-500 hover:bg-gold-600 text-navy-900 font-bold text-xl rounded-lg transition-all duration-200 hover:shadow-lg hover:shadow-gold-500/20"
        >
          Get the Full Suite
          <svg class="w-6 h-6 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <p class="text-navy-500 text-sm mt-6">
          30-day money-back guarantee. No questions asked.
        </p>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
