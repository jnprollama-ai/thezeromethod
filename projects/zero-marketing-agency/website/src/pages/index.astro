---
import Layout from '@layouts/Layout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import Hero from '@components/sections/Hero.astro';
import Pricing from '@components/sections/Pricing.astro';
import FAQ from '@components/sections/FAQ.astro';
import CTA from '@components/sections/CTA.astro';

const title = "Zero Method | AI Prompts That Actually Work";
const description = "25 battle-tested AI prompts + 10 professional email templates. Save 10+ hours every week with copy-paste ready prompts for ChatGPT, Claude, and Gemini.";
---

<Layout title={title} description={description}>
  <Header />
  
  <main>
    <Hero />
    
    <!-- Problem Section -->
    <section class="py-24 lg:py-32 bg-[var(--bg)]" data-reveal>
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="grid lg:grid-cols-5 gap-12 items-center">
          <div class="lg:col-span-2">
            <div class="text-[clamp(120px,15vw,180px)] font-bold text-[var(--gold)] leading-none font-['Playfair_Display']">
              73%
            </div>
            <p class="text-lg text-[var(--text-muted)] mt-4 max-w-sm">
              of professionals waste 2+ hours a day on tasks AI could handle in minutes.
            </p>
          </div>
          
          <div class="lg:col-span-3 space-y-6">
            <div class="flex items-start gap-4">
              <span class="text-[var(--red)] text-2xl mt-1">✕</span>
              <p class="text-lg text-[var(--text)]">Writing the same prompts from scratch, every single time</p>
            </div>
            <div class="flex items-start gap-4">
              <span class="text-[var(--red)] text-2xl mt-1">✕</span>
              <p class="text-lg text-[var(--text)]">Getting generic AI outputs that need complete rewrites</p>
            </div>
            <div class="flex items-start gap-4">
              <span class="text-[var(--red)] text-2xl mt-1">✕</span>
              <p class="text-lg text-[var(--text)]">Losing all context and starting over when sessions reset</p>
            </div>
            
            <p class="text-2xl font-['Playfair_Display'] italic text-[var(--gold)] mt-8">
              There's a better way.
            </p>
          </div>
        </div>
      </div>
    </section>
    
    <!-- What's Inside Section -->
    <section class="py-24 lg:py-32 bg-[var(--surface)]" data-reveal>
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="text-center mb-16">
          <span class="inline-block px-4 py-2 border border-[var(--gold)] text-[var(--gold)] text-xs font-mono uppercase tracking-wider rounded-full mb-6">
            What's Inside
          </span>
          <h2 class="text-4xl lg:text-5xl font-bold text-[var(--text)] font-['Playfair_Display'] mb-4">
            25 Prompts. 5 Categories. Zero Fluff.
          </h2>
          <p class="text-lg text-[var(--text-muted)] max-w-2xl mx-auto">
            Every prompt is tested, refined, and ready to use.
          </p>
        </div>
        
        <!-- Category Tabs -->
        <div class="flex flex-wrap justify-center gap-4 mb-12" id="category-tabs">
          {['Email', 'Reports', 'Content', 'Productivity', 'Research'].map((cat, i) => (
            <button 
              class={`px-6 py-3 text-sm font-medium transition-all ${i === 0 ? 'text-[var(--gold)] border-b-2 border-[var(--gold)]' : 'text-[var(--text-muted)] hover:text-[var(--text)]'}`}
              data-category={cat.toLowerCase()}
            >
              {cat}
            </button>
          ))}
        </div>
        
        <!-- Prompt Cards Grid -->
        <div class="grid md:grid-cols-2 gap-6" id="prompt-cards">
          <div class="bg-[var(--surface-2)] border border-[var(--border)] rounded-lg p-6 border-l-4 border-l-[var(--gold)]">
            <span class="font-mono text-xs text-[var(--gold)] uppercase tracking-wider">Email / Prompt 03</span>
            <h3 class="text-lg font-bold text-[var(--text)] mt-2 mb-3">The 5-Minute Email Polisher</h3>
            <p class="font-mono text-sm text-[var(--text-muted)] line-clamp-3">
              I need to send a professional email about: [topic]... Write a clear, professional email that gets straight to the point...
            </p>
            <a href="#" class="text-[var(--gold)] text-sm mt-4 inline-block hover:underline">5 prompts in this category →</a>
          </div>
          
          <div class="bg-[var(--surface-2)] border border-[var(--border)] rounded-lg p-6 border-l-4 border-l-[var(--gold)]">
            <span class="font-mono text-xs text-[var(--gold)] uppercase tracking-wider">Email / Prompt 05</span>
            <h3 class="text-lg font-bold text-[var(--text)] mt-2 mb-3">Difficult Conversation Starter</h3>
            <p class="font-mono text-sm text-[var(--text-muted)] line-clamp-3">
              I need to [say no to / push back on / address an issue with]: [situation]... Write a response that is clear and direct...
            </p>
            <a href="#" class="text-[var(--gold)] text-sm mt-4 inline-block hover:underline">5 prompts in this category →</a>
          </div>
        </div>
        
        <p class="text-center text-[var(--text-muted)] mt-12">
          Plus 10 email templates — cold outreach, follow-ups, status updates, and more.
        </p>
      </div>
    </section>
    
    <!-- How It Works -->
    <section class="py-24 lg:py-32 bg-[var(--bg)]" data-reveal>
      <div class="max-w-5xl mx-auto px-6 lg:px-8">
        <h2 class="text-4xl font-bold text-[var(--text)] font-['Playfair_Display'] text-center mb-16">
          How It Works
        </h2>
        
        <div class="grid md:grid-cols-3 gap-8">
          <div class="text-center">
            <span class="text-7xl font-bold text-[var(--gold)] opacity-40 font-['Playfair_Display']">01</span>
            <h3 class="text-xl font-bold text-[var(--text)] mt-4 mb-2">Download</h3>
            <p class="text-[var(--text-muted)]">Instant delivery. PDF and Markdown files, organized by category.</p>
          </div>
          
          <div class="text-center">
            <span class="text-7xl font-bold text-[var(--gold)] opacity-40 font-['Playfair_Display']">02</span>
            <h3 class="text-xl font-bold text-[var(--text)] mt-4 mb-2">Find Your Prompt</h3>
            <p class="text-[var(--text-muted)]">5 categories, 25 prompts, all indexed. Find what you need in under 30 seconds.</p>
          </div>
          
          <div class="text-center">
            <span class="text-7xl font-bold text-[var(--gold)] opacity-40 font-['Playfair_Display']">03</span>
            <h3 class="text-xl font-bold text-[var(--text)] mt-4 mb-2">Paste and Execute</h3>
            <p class="text-[var(--text-muted)]">Customize the bracket fields. Run it. Save 30–60 minutes per task.</p>
          </div>
        </div>
      </div>
    </section>
    
    <!-- Social Proof -->
    <section class="py-24 lg:py-32 bg-[var(--surface)]" data-reveal>
      <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center">
        <div class="bg-[var(--surface-2)] border border-[var(--border)] rounded-xl p-8 lg:p-12 border-t-4 border-t-[var(--gold)]">
          <p class="text-2xl font-['Playfair_Display'] italic text-[var(--text)] leading-relaxed mb-6">
            "I used to spend 45 minutes writing executive summaries. Now it takes 8. That's not a feature — that's a refund on my afternoon."
          </p>
          <p class="text-sm text-[var(--text-muted)]">— Sarah K., Operations Director</p>
        </div>
        
        <div class="grid md:grid-cols-3 gap-8 mt-16">
          <div class="text-center">
            <div class="text-5xl font-bold text-[var(--gold)] font-['Playfair_Display']">25</div>
            <p class="text-[var(--text-muted)] mt-2">Prompts across 5 professional categories</p>
          </div>
          <div class="text-center">
            <div class="text-5xl font-bold text-[var(--gold)] font-['Playfair_Display']">10</div>
            <p class="text-[var(--text-muted)] mt-2">Email templates, ready to send</p>
          </div>
          <div class="text-center">
            <div class="text-5xl font-bold text-[var(--gold)] font-['Playfair_Display']">30</div>
            <p class="text-[var(--text-muted)] mt-2">Day money-back guarantee</p>
          </div>
        </div>
      </div>
    </section>
    
    <Pricing />
    <FAQ />
    <CTA />
  </main>
  
  <Footer />
</Layout>

<style>
  @keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  [data-reveal] {
    opacity: 0;
    transform: translateY(20px);
  }
  
  [data-reveal].revealed {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 600ms cubic-bezier(0.16, 1, 0.3, 1), transform 600ms cubic-bezier(0.16, 1, 0.3, 1);
  }
</style>

<script>
  // Scroll reveal
  const observer = new IntersectionObserver(
    entries => entries.forEach(e => { 
      if (e.isIntersecting) { 
        e.target.classList.add('revealed'); 
        observer.unobserve(e.target); 
      } 
    }),
    { threshold: 0.15 }
  );
  
  document.querySelectorAll('[data-reveal]').forEach(el => observer.observe(el));
</script>