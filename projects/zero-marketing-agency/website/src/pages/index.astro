---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';

const title = "Zero Method | AI Prompts Starter Pack";
const description = "25 battle-tested AI prompts + 10 professional email templates. Save 5 hours every week with copy-paste ready prompts for ChatGPT and Claude.";

// Typewriter prompt examples
const promptExamples = [
  "Write a professional cold email to a potential client...",
  "Summarize this meeting transcript into action items...",
  "Create a weekly status report from these bullet points...",
  "Draft a response to this difficult customer complaint...",
  "Generate 5 LinkedIn post ideas from this article..."
];

// Features section
const features = [
  {
    title: "25 Tested Prompts",
    description: "25 carefully crafted prompts across 5 categories. Each one tested and refined for consistent, high-quality results.",
    icon: "zap"
  },
  {
    title: "10 Email Templates",
    description: "Professional email templates for cold outreach, follow-ups, meeting requests, and difficult conversations.",
    icon: "mail"
  },
  {
    title: "PDF + Markdown",
    description: "Get both formats. PDF for offline reading, Markdown for easy copying and editing. Works on any device.",
    icon: "file"
  },
  {
    title: "Instant Access",
    description: "No waiting. Download immediately after purchase. Start saving time within minutes.",
    icon: "download"
  },
  {
    title: "Free Updates",
    description: "Receive updates for a full year. As AI evolves, your prompts stay current and effective.",
    icon: "refresh"
  },
  {
    title: "30-Day Guarantee",
    description: "Not satisfied? Get a full refund within 30 days. No questions asked.",
    icon: "shield"
  }
];

// Pain points
const painPoints = [
  {
    icon: "clock",
    title: "Drowning in Busywork",
    description: "Hours wasted on emails, reports, and repetitive tasks that should be faster."
  },
  {
    icon: "brain",
    title: "AI Confusion",
    description: "Everyone's talking about AI, but you don't know where to start. Prompts feel like guesswork."
  },
  {
    icon: "trending",
    title: "Inconsistent Results",
    description: "When you try AI, output is hit-or-miss. No system, no consistency, no time saved."
  }
];

// Solutions
const solutions = [
  {
    icon: "zap",
    title: "25 Battle-Tested Prompts",
    description: "Proven prompts that eliminate busywork. Copy, paste, and watch the magic happen. Organized by category: Email, Reports, Content, Productivity, Research."
  },
  {
    icon: "template",
    title: "10 Professional Templates",
    description: "Done-for-you email templates for every situation. Cold outreach, follow-ups, saying no professionally, and more."
  },
  {
    icon: "target",
    title: "Clear Instructions",
    description: "Each prompt includes usage instructions. Know exactly how to customize for your specific situation."
  }
];

// How it works steps
const howItWorks = [
  {
    step: "01",
    title: "Purchase",
    description: "One-time payment of $19. No subscriptions, no hidden fees."
  },
  {
    step: "02",
    title: "Download",
    description: "Get instant access to PDF and Markdown files. Works on any device."
  },
  {
    step: "03",
    title: "Copy & Paste",
    description: "Open the file, find what you need, copy the prompt, paste into ChatGPT or Claude."
  },
  {
    step: "04",
    title: "Save Time",
    description: "Watch 2-hour tasks become 15-minute tasks. Reclaim your week."
  }
];

// Testimonials
const testimonials = [
  {
    quote: "These prompts paid for themselves in the first day. My client emails now take minutes instead of hours.",
    author: "Sarah Chen",
    role: "Freelance Consultant",
    avatar: "SC"
  },
  {
    quote: "Finally, prompts that actually work. No more trial and error. I just copy, paste, and get results.",
    author: "Marcus Johnson",
    role: "Marketing Manager",
    avatar: "MJ"
  },
  {
    quote: "The email templates alone are worth the price. Professional, effective, and save me so much mental energy.",
    author: "Emily Rodriguez",
    role: "Startup Founder",
    avatar: "ER"
  }
];

// Pricing tiers
const pricing = [
  {
    name: "Starter",
    price: "$19",
    description: "One-time payment",
    features: [
      "25 AI prompts",
      "10 email templates",
      "PDF + Markdown formats",
      "Free updates (1 year)",
      "30-day guarantee"
    ],
    cta: "Get Started",
    highlighted: true
  }
];
---

<Layout title={title} description={description}>
  <Header />

  <main class="bg-[var(--bg)]">
    <!-- Section 1: Hero -->
    <section class="relative min-h-screen flex items-center pt-20 lg:pt-0 overflow-hidden">
      <!-- Background gradient -->
      <div class="absolute inset-0 bg-gradient-to-b from-[var(--surface)] via-[var(--bg)] to-[var(--bg)]"></div>
      
      <!-- Decorative elements -->
      <div class="absolute top-1/4 left-0 w-96 h-96 bg-[var(--gold)] opacity-[0.03] rounded-full blur-3xl"></div>
      <div class="absolute bottom-1/4 right-0 w-80 h-80 bg-[var(--gold)] opacity-[0.02] rounded-full blur-3xl"></div>

      <div class="relative w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          <!-- Left: Content -->
          <div class="text-center lg:text-left animate-on-scroll" data-animation="fadeSlideUp">
            <!-- Badge -->
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[var(--gold)]/10 border border-[var(--gold)]/20 mb-6 sm:mb-8">
              <span class="w-2 h-2 rounded-full bg-[var(--gold)] animate-pulse"></span>
              <span class="font-mono text-sm text-[var(--gold)] tracking-wide">25 PROMPTS + 10 TEMPLATES</span>
            </div>

            <!-- Headline -->
            <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold text-[var(--text)] leading-[1.1] mb-6">
              Save <span class="text-[var(--gold)]">5 Hours</span> Every Week
            </h1>

            <p class="text-lg sm:text-xl text-[var(--text-muted)] mb-8 max-w-xl mx-auto lg:mx-0 leading-relaxed">
              25 battle-tested AI prompts and 10 professional email templates. Copy, paste, done. No videos. No fluff. Just results.
            </p>

            <!-- CTAs -->
            <div class="flex flex-col sm:flex-row items-center gap-4 justify-center lg:justify-start mb-8">
              <a
                href="#pricing"
                class="inline-flex items-center px-8 py-4 bg-[var(--gold)] hover:bg-[var(--gold-dim)] text-[var(--bg)] font-semibold text-lg rounded-lg transition-all duration-200 hover:shadow-lg hover:shadow-[var(--gold)]/20 animate-on-scroll"
                data-animation="fadeSlideUp"
                style="animation-delay: 0.1s;"
              >
                Get the Pack — $19
                <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
              </a>
              <a
                href="#how-it-works"
                class="inline-flex items-center px-8 py-4 border border-[var(--border)] text-[var(--text)] font-medium rounded-lg hover:bg-[var(--surface-2)] transition-all duration-200"
              >
                See How It Works
              </a>
            </div>

            <!-- Trust signals -->
            <div class="flex flex-wrap items-center justify-center lg:justify-start gap-4 sm:gap-6 text-[var(--text-muted)] text-sm">
              <div class="flex items-center gap-2">
                <svg class="w-5 h-5 text-[var(--gold)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>30-Day Guarantee</span>
              </div>
              <div class="flex items-center gap-2">
                <svg class="w-5 h-5 text-[var(--gold)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Instant Download</span>
              </div>
              <div class="flex items-center gap-2">
                <svg class="w-5 h-5 text-[var(--gold)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Free Updates</span>
              </div>
            </div>
          </div>

          <!-- Right: Prompt Card -->
          <div class="animate-on-scroll" data-animation="fadeSlideUp" style="animation-delay: 0.2s;">
            <div class="relative bg-[var(--surface)] border border-[var(--border)] rounded-2xl p-6 sm:p-8 shadow-2xl">
              <!-- Terminal header -->
              <div class="flex items-center gap-2 mb-6 pb-4 border-b border-[var(--border)]">
                <div class="w-3 h-3 rounded-full bg-[var(--red)]"></div>
                <div class="w-3 h-3 rounded-full bg-[var(--gold)]"></div>
                <div class="w-3 h-3 rounded-full bg-[var(--green)]"></div>
                <span class="ml-4 font-mono text-xs text-[var(--text-muted)]">prompt.txt</span>
              </div>

              <!-- Typewriter content -->
              <div class="min-h-[120px]">
                <p class="font-mono text-sm sm:text-base text-[var(--text)] leading-relaxed">
                  <span class="text-[var(--green)]">➜</span> <span class="text-[var(--gold)]">~</span> 
                  <span id="typewriter-text"></span><span class="animate-pulse text-[var(--gold)]">|</span>
                </p>
              </div>

              <!-- Prompt indicator -->
              <div class="mt-6 flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-[var(--gold)] animate-pulse"></div>
                <span id="prompt-indicator" class="font-mono text-xs text-[var(--text-muted)]">Example prompt 1/5</span>
              </div>
            </div>

            <!-- Floating stats -->
            <div class="absolute -bottom-4 -right-4 sm:bottom-8 sm:-right-8 bg-[var(--surface-2)] border border-[var(--border)] rounded-xl p-4 shadow-xl animate-on-scroll" data-animation="fadeSlideUp" style="animation-delay: 0.3s;">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-[var(--gold)]/20 flex items-center justify-center">
                  <svg class="w-5 h-5 text-[var(--gold)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <p class="text-[var(--text)] font-semibold">5 hours</p>
                  <p class="text-[var(--text-muted)] text-xs">saved weekly</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 2: What's Included -->
    <section class="py-20 sm:py-24 lg:py-32" id="features">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Section header -->
        <div class="text-center max-w-3xl mx-auto mb-12 sm:mb-16 animate-on-scroll" data-animation="fadeSlideUp">
          <span class="font-mono text-sm text-[var(--gold)] tracking-wider mb-4 block">WHAT'S INCLUDED</span>
          <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--text)] mb-4">
            Everything You Need
          </h2>
          <p class="text-lg text-[var(--text-muted)]">
            No fluff. No upsells. Just practical tools that save time.
          </p>
        </div>

        <!-- Features grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {features.map((feature, index) => (
            <div 
              class="group p-6 sm:p-8 bg-[var(--surface)] border border-[var(--border)] rounded-xl hover:border-[var(--gold)]/30 transition-all duration-300 animate-on-scroll"
              data-animation="fadeSlideUp"
              style={`animation-delay: ${index * 0.1}s;`}
            >
              <div class="w-12 h-12 rounded-lg bg-[var(--gold)]/10 flex items-center justify-center mb-6 group-hover:bg-[var(--gold)]/20 transition-colors">
                {feature.icon === 'zap' && (
                  <svg class="w-6 h-6 text-[var(--gold)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                  </svg>
                )}
                {feature.icon === 'mail' && (
                  <svg class="w-6 h-6 text-[var(--gold)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                )}
                {feature.icon === 'file' && (
                  <svg class="w-6 h-6 text-[var(--gold)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                )}
                {feature.icon === 'download' && (
                  <svg class="w-6 h-6 text-[var(--gold)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                  </svg>
                )}
                {feature.icon === 'refresh' && (
                  <svg class="w-6 h-6 text-[var(--gold)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                  </svg>
                )}
                {feature.icon === 'shield' && (
                  <svg class="w-6 h-6 text-[var(--gold)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                  </svg>
                )}
              </div>
              <h3 class="font-display text-xl font-semibold text-[var(--text)] mb-3">{feature.title}</h3>
              <p class="text-[var(--text-muted)] leading-relaxed">{feature.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Section 3: Pain Points -->
    <section class="py-20 sm:py-24 lg:py-32 bg-[var(--surface)]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-3xl mx-auto mb-12 sm:mb-16 animate-on-scroll" data-animation="fadeSlideUp">
          <span class="font-mono text-sm text-[var(--gold)] tracking-wider mb-4 block">THE PROBLEM</span>
          <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--text)] mb-4">
            Sound Familiar?
          </h2>
          <p class="text-lg text-[var(--text-muted)]">
            You're busy. But are you actually productive?
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
          {painPoints.map((point, index) => (
            <div 
              class="text-center p-8 sm:p-10 border border-[var(--border)] rounded-xl animate-on-scroll"
              data-animation="fadeSlideUp"
              style={`animation-delay: ${index * 0.1}s;`}
            >
              <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-[var(--surface-2)] flex items-center justify-center">
                {point.icon === 'clock' && (
                  <svg class="w-8 h-8 text-[var(--text-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                )}
                {point.icon === 'brain' && (
                  <svg class="w-8 h-8 text-[var(--text-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                  </svg>
                )}
                {point.icon === 'trending' && (
                  <svg class="w-8 h-8 text-[var(--text-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                  </svg>
                )}
              </div>
              <h3 class="font-display text-xl font-semibold text-[var(--text)] mb-3">{point.title}</h3>
              <p class="text-[var(--text-muted)]">{point.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Section 4: Solution -->
    <section class="py-20 sm:py-24 lg:py-32">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-3xl mx-auto mb-12 sm:mb-16 animate-on-scroll" data-animation="fadeSlideUp">
          <span class="font-mono text-sm text-[var(--gold)] tracking-wider mb-4 block">THE SOLUTION</span>
          <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--text)] mb-4">
            A Better Way
          </h2>
          <p class="text-lg text-[var(--text-muted)]">
            Everything you need to turn AI into your personal productivity engine.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
          {solutions.map((solution, index) => (
            <div 
              class="relative p-8 sm:p-10 bg-[var(--surface)] border border-[var(--border)] rounded-xl overflow-hidden group hover:border-[var(--gold)]/30 transition-all duration-300 animate-on-scroll"
              data-animation="fadeSlideUp"
              style={`animation-delay: ${index * 0.1}s;`}
            >
              <!-- Subtle gradient overlay on hover -->
              <div class="absolute inset-0 bg-gradient-to-br from-[var(--gold)]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
              
              <div class="relative">
                <div class="w-12 h-12 rounded-lg bg-[var(--gold)]/10 flex items-center justify-center mb-6">
                  {solution.icon === 'zap' && (
                    <svg class="w-6 h-6 text-[var(--gold)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                  )}
                  {solution.icon === 'template' && (
                    <svg class="w-6 h-6 text-[var(--gold)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z" />
                    </svg>
                  )}
                  {solution.icon === 'target' && (
                    <svg class="w-6 h-6 text-[var(--gold)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  )}
                </div>
                <h3 class="font-display text-xl font-semibold text-[var(--text)] mb-3">{solution.title}</h3>
                <p class="text-[var(--text-muted)] leading-relaxed">{solution.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Section 5: How It Works -->
    <section class="py-20 sm:py-24 lg:py-32 bg-[var(--surface)]" id="how-it-works">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-3xl mx-auto mb-12 sm:mb-16 animate-on-scroll" data-animation="fadeSlideUp">
          <span class="font-mono text-sm text-[var(--gold)] tracking-wider mb-4 block">PROCESS</span>
          <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--text)] mb-4">
            How It Works
          </h2>
          <p class="text-lg text-[var(--text-muted)]">
            Four simple steps to reclaim your time.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
          {howItWorks.map((step, index) => (
            <div 
              class="relative animate-on-scroll"
              data-animation="fadeSlideUp"
              style={`animation-delay: ${index * 0.1}s;`}
            >
              <!-- Step number -->
              <div class="font-mono text-5xl sm:text-6xl font-bold text-[var(--gold)]/20 mb-4">{step.step}</div>
              <h3 class="font-display text-xl font-semibold text-[var(--text)] mb-2">{step.title}</h3>
              <p class="text-[var(--text-muted)]">{step.description}</p>
              
              <!-- Connector line (hidden on mobile, visible on lg) -->
              {index < howItWorks.length - 1 && (
                <div class="hidden lg:block absolute top-8 left-full w-full h-px bg-gradient-to-r from-[var(--border)] to-transparent"></div>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Section 6: Testimonials -->
    <section class="py-20 sm:py-24 lg:py-32">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-3xl mx-auto mb-12 sm:mb-16 animate-on-scroll" data-animation="fadeSlideUp">
          <span class="font-mono text-sm text-[var(--gold)] tracking-wider mb-4 block">TESTIMONIALS</span>
          <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--text)] mb-4">
            What People Say
          </h2>
          <p class="text-lg text-[var(--text-muted)]">
            Join thousands who've already saved time.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
          {testimonials.map((testimonial, index) => (
            <div 
              class="p-6 sm:p-8 bg-[var(--surface)] border border-[var(--border)] rounded-xl animate-on-scroll"
              data-animation="fadeSlideUp"
              style={`animation-delay: ${index * 0.1}s;`}
            >
              <!-- Quote marks -->
