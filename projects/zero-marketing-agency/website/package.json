    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.18.0",
    "puppeteer": "^24.40.0",
    "stripe": "^14.0.0",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@lhci/cli": "^0.14.0",
